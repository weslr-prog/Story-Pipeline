# Core runtime
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
WRITER_MODEL=
EDITOR_MODEL=
CRITIC_MODEL=
ARCHIVIST_MODEL=
TTS_PREP_MODEL=
LLM_NUM_CTX=4096
CHATTERBOX_URL=http://127.0.0.1:7860
CHATTERBOX_API=

# Critic workflow
CRITIC_MODE=local
REVIEWS_DIR=reviews
PAUSE_FOR_EXTERNAL_CRITIC=true
PAUSE_BEFORE_NARRATION_REVIEW=true
PAUSE_AFTER_CHAPTER_REVIEW=true

# Story sizing
CHAPTER_COUNT=10
WORD_TARGET_MIN=1800
WORD_TARGET_MAX=2400
TARGET_MINUTES_MIN=0
TARGET_MINUTES_MAX=0
ASSUMED_WPM=150
EXPANSION_PASSES=1

# Deterministic lint gates
LINT_ENABLED=true
MAX_LINT_REPAIRS=1
MAX_DUPLICATE_PARAGRAPH_REPEATS=1
MAX_SENTENCE_REPEAT=2
META_PHRASES=this is only the beginning,on a journey,story had only started,dear reader,in this chapter,the author,the writer,prompt,model,ai
CHAPTER1_FORBIDDEN_TERMS=hidden door,novaBio tracker,tracker lay hidden

# Optional style influence traits (high-level only)
STYLE_INFLUENCE=

# TTS tuning for stability
EXAGGERATION=0.40
CFG_WEIGHT=0.60
TEMPERATURE=0.70
SILENCE_PAD=0.60
SAMPLE_RATE=22050
REQUEST_DELAY=1.00
MAX_RETRIES=3
RETRY_BACKOFF=1.00

# Paths
VOICE_SAMPLE=voices/narrator.wav
